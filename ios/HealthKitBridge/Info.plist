<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- HealthKit usage descriptions (required for App Store and Health access) -->
	<key>NSHealthShareUsageDescription</key>
	<string>HealthKit Bridge reads all your health and fitness data to sync it to your personal Supabase database for analysis and archival.</string>
	<key>NSHealthUpdateUsageDescription</key>
	<string>HealthKit Bridge does not write health data.</string>

	<!-- UIBackgroundModes omitted: 'fetch' triggers XPC service registration crash on iOS 27 Beta -->
	<!-- Re-add when iOS 27 fixes the libxpc _xpc_init_service bug: -->
	<!-- <key>UIBackgroundModes</key><array><string>fetch</string></array> -->

	<!-- BGTaskSchedulerPermittedIdentifiers omitted: triggers same XPC crash -->
	<!-- Re-add com.healthkitbridge.sync + com.healthkitbridge.backfill when iOS 27 fixes XPC -->

	<!-- iOS 27 Beta 1 requires UIApplicationSceneManifest even for apps built with older SDKs.
	     Without it, iOS 27 uses a legacy XPC launch path that crashes in _xpc_init_service.
	     SwiftUI App protocol handles scene delegation automatically; empty UISceneConfigurations is correct. -->
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<false/>
		<key>UISceneConfigurations</key>
		<dict/>
	</dict>

	<!-- Standard app metadata -->
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleDisplayName</key>
	<string>HKBridge</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleShortVersionString</key>
	<string>1.0</string>
	<key>CFBundleVersion</key>
	<string>1</string>

	<!-- Require iOS 17 -->
	<key>MinimumOSVersion</key>
	<string>17.0</string>

	<!-- UI -->
	<key>UILaunchScreen</key>
	<dict/>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>arm64</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>

	<!-- App Transport Security: allow HTTPS only (Supabase is always HTTPS) -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<false/>
	</dict>
</dict>
</plist>
