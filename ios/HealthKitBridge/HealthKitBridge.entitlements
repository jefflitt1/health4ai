<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- HealthKit read access -->
	<key>com.apple.developer.healthkit</key>
	<true/>

	<!-- Allows HKObserverQuery delivery while app is backgrounded -->
	<key>com.apple.developer.healthkit.background-delivery</key>
	<true/>

	<!-- HealthKit capability type lists (iOS 17+: list all capabilities used) -->
	<key>com.apple.developer.healthkit.access</key>
	<array>
		<string>health-records</string>
	</array>

	<!-- Keychain sharing (optional: enables sharing with extensions) -->
	<!-- Remove this block if you don't need keychain sharing with an app extension -->
	<!-- <key>keychain-access-groups</key>
	<array>
		<string>$(AppIdentifierPrefix)com.healthkitbridge</string>
	</array> -->
</dict>
</plist>
