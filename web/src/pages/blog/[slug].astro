---
import Layout from '../../layouts/Layout.astro';
import { getCollection, getEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map(post => ({ params: { slug: post.slug } }));
}

const { slug } = Astro.params;
const post = await getEntry('blog', slug as string);

if (!post) {
  return Astro.redirect('/blog');
}

const { Content } = await post.render();

function formatDate(d: Date) {
  return new Date(d).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
}
---
<Layout
  title={`${post.data.title} — health4.ai`}
  description={post.data.description}
>
<style>
  .prose { color: #a0aec0; line-height: 1.8; font-size: 0.95rem; }
  .prose h1 { color: #fff; font-size: 1.6rem; font-weight: 700; margin: 2rem 0 0.75rem; line-height: 1.25; }
  .prose h2 { color: #e2e8f0; font-size: 1.15rem; font-weight: 600; margin: 2rem 0 0.6rem; line-height: 1.3; }
  .prose h3 { color: #e2e8f0; font-size: 1rem; font-weight: 600; margin: 1.5rem 0 0.5rem; }
  .prose p { margin: 0 0 1.2rem; }
  .prose a { color: #ff2d78; text-decoration: underline; text-underline-offset: 3px; }
  .prose a:hover { opacity: 0.85; }
  .prose ul, .prose ol { margin: 0 0 1.2rem 1.4rem; }
  .prose li { margin-bottom: 0.35rem; }
  .prose pre { background: #06070f; border: 1px solid rgba(255,255,255,0.07); border-radius: 10px; padding: 18px 22px; margin: 1.4rem 0; overflow-x: auto; font-family: ui-monospace,'SF Mono',monospace; font-size: 0.8rem; line-height: 1.7; color: #c8d0e8; }
  .prose code { font-family: ui-monospace,'SF Mono',monospace; font-size: 0.82rem; background: rgba(255,255,255,0.06); border-radius: 4px; padding: 2px 5px; color: #e2c8d4; }
  .prose pre code { background: transparent; padding: 0; border-radius: 0; color: inherit; }
  .prose strong { color: #e2e8f0; font-weight: 600; }
  .prose blockquote { border-left: 3px solid rgba(255,45,120,0.4); padding-left: 1rem; margin: 1.4rem 0; color: #718096; font-style: italic; }
  .prose hr { border: none; border-top: 1px solid rgba(255,255,255,0.08); margin: 2rem 0; }
  .prose table { width: 100%; border-collapse: collapse; margin: 1.4rem 0; font-size: 0.85rem; }
  .prose th { text-align: left; padding: 8px 12px; color: #e2e8f0; font-weight: 600; border-bottom: 1px solid rgba(255,255,255,0.1); }
  .prose td { padding: 8px 12px; border-bottom: 1px solid rgba(255,255,255,0.05); }
</style>

<nav class="flex items-center justify-between px-6 py-4 max-w-6xl mx-auto">
  <a href="/" class="flex items-center gap-2.5">
    <img src="/logo.png" alt="health4.ai" class="w-8 h-8 rounded-xl" />
    <span class="font-bold text-white tracking-tight text-[15px]">health4.ai</span>
  </a>
  <div class="flex items-center gap-5 text-sm" style="color:var(--muted)">
    <a href="/how-it-works" class="hover:text-white transition-colors hidden sm:inline">How it works</a>
    <a href="/compare" class="hover:text-white transition-colors hidden sm:inline">Compare</a>
    <a href="/blog" class="hover:text-white transition-colors hidden sm:inline">Blog</a>
    <a href="https://github.com/jefflitt1/health4ai" target="_blank" rel="noopener" class="hover:text-white transition-colors">GitHub</a>
  </div>
</nav>

<!-- Canonical + OG for article -->
<link rel="canonical" href={`https://health4.ai/blog/${post.slug}`} slot="head" />
<meta property="og:type" content="article" slot="head" />
<meta property="article:published_time" content={new Date(post.data.pubDate).toISOString()} slot="head" />

<main class="px-6 py-10 max-w-[680px] mx-auto">
  <a href="/blog" class="inline-flex items-center gap-1.5 text-xs mb-8 transition-colors hover:text-white" style="color:var(--muted)">
    ← All posts
  </a>

  <div class="mb-8">
    <div class="flex items-center gap-3 text-xs mb-3" style="color:var(--muted)">
      <span>{formatDate(post.data.pubDate)}</span>
      {post.data.tags.length > 0 && (
        <>
          <span>·</span>
          {post.data.tags.slice(0, 3).map(tag => (
            <span class="px-2 py-0.5 rounded-full text-[10px]" style="background:rgba(255,45,120,0.08);border:1px solid rgba(255,45,120,0.15)">{tag}</span>
          ))}
        </>
      )}
    </div>
    <h1 class="text-2xl sm:text-3xl font-bold text-white leading-snug">{post.data.title}</h1>
  </div>

  <article class="prose">
    <Content />
  </article>
</main>
</Layout>
