---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => {
  return !data.draft && new Date(data.pubDate) <= new Date();
});

const posts = allPosts.sort((a, b) =>
  new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf()
);

function readTime(body: string | undefined) {
  if (!body) return '5 min read';
  const words = body.split(/\s+/).length;
  return `${Math.max(1, Math.round(words / 200))} min read`;
}

function formatDate(d: Date) {
  return new Date(d).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}
---
<Layout
  title="Blog — health4.ai"
  description="Guides, tutorials, and deep dives on connecting Apple Health data to Claude Code, Cursor, and AI agents."
>
<nav class="flex items-center justify-between px-6 py-4 max-w-6xl mx-auto">
  <a href="/" class="flex items-center gap-2.5">
    <img src="/logo.png" alt="health4.ai" class="w-8 h-8 rounded-xl" />
    <span class="font-bold text-white tracking-tight text-[15px]">health4.ai</span>
  </a>
  <div class="flex items-center gap-5 text-sm" style="color:var(--muted)">
    <a href="/how-it-works" class="hover:text-white transition-colors hidden sm:inline">How it works</a>
    <a href="/compare" class="hover:text-white transition-colors hidden sm:inline">Compare</a>
    <a href="/blog" class="hover:text-white transition-colors hidden sm:inline text-white">Blog</a>
    <a href="https://github.com/jefflitt1/health4ai" target="_blank" rel="noopener" class="hover:text-white transition-colors">GitHub</a>
  </div>
</nav>

<main class="px-6 py-12 max-w-3xl mx-auto">
  <h1 class="text-2xl font-bold text-white mb-2">Blog</h1>
  <p class="text-sm mb-10" style="color:var(--muted)">Guides and tutorials on Apple Health, MCP, and AI-native health data workflows.</p>

  {posts.length === 0 && (
    <p class="text-sm" style="color:var(--muted)">No posts published yet — check back soon.</p>
  )}

  <div class="flex flex-col gap-6">
    {posts.map(post => (
      <a
        href={`/blog/${post.slug}`}
        class="group block p-5 rounded-xl border transition-colors"
        style="border-color:var(--border);background:rgba(255,255,255,0.02)"
      >
        <div class="flex items-center gap-3 mb-2 text-xs" style="color:var(--muted)">
          <span>{formatDate(post.data.pubDate)}</span>
          <span>·</span>
          <span>{readTime(post.body)}</span>
        </div>
        <h2 class="text-white font-semibold text-base leading-snug mb-2 group-hover:text-[var(--accent)] transition-colors">
          {post.data.title}
        </h2>
        <p class="text-sm leading-relaxed" style="color:var(--muted)">{post.data.description}</p>
        {post.data.tags.length > 0 && (
          <div class="flex flex-wrap gap-1.5 mt-3">
            {post.data.tags.slice(0, 4).map(tag => (
              <span class="text-[10px] px-2 py-0.5 rounded-full" style="background:rgba(255,45,120,0.08);color:var(--muted);border:1px solid rgba(255,45,120,0.15)">{tag}</span>
            ))}
          </div>
        )}
      </a>
    ))}
  </div>
</main>
</Layout>
