<script define:vars={{ SUPABASE_URL, SUPABASE_ANON_KEY }}>
  // Waitlist submission
  async function submitWaitlist(email, statusEl) {
    statusEl.textContent = 'Submitting…';
    try {
      const res = await fetch(`${SUPABASE_URL}/rest/v1/health4ai_waitlist`, {
        method: 'POST',
        headers: {
          'apikey': SUPABASE_ANON_KEY,
          'Authorization': `Bearer ${SUPABASE_ANON_KEY}`,
          'Content-Type': 'application/json',
          'Prefer': 'return=minimal',
        },
        body: JSON.stringify({ email }),
      });
      if (res.ok || res.status === 409) {
        statusEl.textContent = res.status === 409 ? "You're already on the list." : "You're on the list — we'll email you at launch.";
        statusEl.style.color = '#ff6b9d';
      } else {
        throw new Error(res.status);
      }
    } catch {
      statusEl.textContent = 'Something went wrong. Try again.';
      statusEl.style.color = '#ff5577';
    }
  }
  document.getElementById('waitlist-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    await submitWaitlist(document.getElementById('email-input').value, document.getElementById('form-status'));
  });
  document.getElementById('waitlist-form-2')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    await submitWaitlist(document.getElementById('email-input-2').value, document.getElementById('form-status-2'));
  });

  // Backend tabs
  document.getElementById('backend-tabs')?.addEventListener('click', (e) => {
    const btn = e.target.closest('.tab-btn');
    if (!btn) return;
    const tab = btn.dataset.tab;
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.toggle('active', b === btn));
    document.querySelectorAll('.backend-content').forEach(c => {
      c.hidden = c.id !== `tab-${tab}`;
    });
  });
</script>
