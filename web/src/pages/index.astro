---
import Layout from '../layouts/Layout.astro';
const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL;
const SUPABASE_ANON_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
---
<Layout>
  <!-- Nav -->
  <nav class="flex items-center justify-between px-6 py-5 max-w-5xl mx-auto">
    <span class="text-green-400 font-bold text-lg tracking-tight">health4.ai</span>
    <a
      href="https://github.com/jefflitt1/health4ai"
      target="_blank"
      rel="noopener"
      class="text-sm text-neutral-400 hover:text-white transition-colors flex items-center gap-2"
    >
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/></svg>
      GitHub
    </a>
  </nav>

  <!-- Hero -->
  <section class="px-6 pt-16 pb-24 max-w-5xl mx-auto">
    <div class="max-w-2xl">
      <div class="inline-flex items-center gap-2 text-xs text-green-400 border border-green-400/30 rounded-full px-3 py-1 mb-8">
        <span class="w-1.5 h-1.5 bg-green-400 rounded-full animate-pulse"></span>
        Open source · MIT licensed · Coming to App Store
      </div>

      <h1 class="text-4xl sm:text-5xl font-bold leading-tight text-white mb-6">
        Your Apple Health data.<br />
        <span class="text-green-400">For AI.</span>
      </h1>

      <p class="text-neutral-400 text-lg leading-relaxed mb-10 max-w-xl">
        health4.ai syncs HealthKit to the cloud and gives Claude, n8n, and any AI agent
        native access via MCP. Works from anywhere — no same-WiFi required.
      </p>

      <!-- Waitlist form -->
      <form id="waitlist-form" class="flex flex-col sm:flex-row gap-3 max-w-md">
        <input
          type="email"
          id="email-input"
          placeholder="your@email.com"
          required
          class="flex-1 bg-neutral-900 border border-neutral-700 rounded-lg px-4 py-3 text-white placeholder-neutral-500 focus:outline-none focus:border-green-400 transition-colors text-sm"
        />
        <button
          type="submit"
          class="bg-green-500 hover:bg-green-400 text-black font-semibold px-6 py-3 rounded-lg transition-colors text-sm whitespace-nowrap"
        >
          Join waitlist
        </button>
      </form>
      <p id="form-status" class="text-sm mt-3 text-neutral-500 min-h-[20px]"></p>
    </div>
  </section>

  <!-- Code snippet -->
  <section class="px-6 py-16 border-t border-neutral-800/60">
    <div class="max-w-5xl mx-auto">
      <p class="text-xs text-neutral-500 uppercase tracking-widest mb-6">What it looks like in Claude Code</p>
      <div class="bg-neutral-900 rounded-xl border border-neutral-800 p-6 overflow-x-auto">
        <pre class="text-sm text-neutral-300 leading-relaxed"><code><span class="text-neutral-500"># claude_desktop_config.json</span>
<span class="text-neutral-400">{</span>
  <span class="text-green-400">"mcpServers"</span><span class="text-neutral-400">: {</span>
    <span class="text-green-400">"health4ai"</span><span class="text-neutral-400">: {</span>
      <span class="text-green-400">"command"</span><span class="text-neutral-400">: </span><span class="text-amber-300">"npx"</span><span class="text-neutral-400">,</span>
      <span class="text-green-400">"args"</span><span class="text-neutral-400">: [</span><span class="text-amber-300">"health4ai-mcp"</span><span class="text-neutral-400">],</span>
      <span class="text-green-400">"env"</span><span class="text-neutral-400">: { </span><span class="text-green-400">"HEALTH4AI_TOKEN"</span><span class="text-neutral-400">: </span><span class="text-amber-300">"your-token"</span><span class="text-neutral-400"> }</span>
    <span class="text-neutral-400">}</span>
  <span class="text-neutral-400">}</span>
<span class="text-neutral-400">}</span>

<span class="text-neutral-500"># Claude Code can now call:</span>
<span class="text-blue-400">get_sleep_last_night</span><span class="text-neutral-400">()</span>       <span class="text-neutral-500">→ HRV, deep sleep, duration</span>
<span class="text-blue-400">get_activity_today</span><span class="text-neutral-400">()</span>          <span class="text-neutral-500">→ steps, active cal, exercise min</span>
<span class="text-blue-400">query_health_metric</span><span class="text-neutral-400">(metric, start, end)  </span><span class="text-neutral-500">→ raw time series</span></code></pre>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="px-6 py-20 max-w-5xl mx-auto">
    <p class="text-xs text-neutral-500 uppercase tracking-widest mb-12">How it works</p>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-8">
      {[
        {
          step: '01',
          title: 'Install the iOS app',
          body: 'One tap to authorize HealthKit. Background sync starts immediately — HKObserverQuery + BGProcessingTask, not a manual export.',
        },
        {
          step: '02',
          title: 'Data goes to the cloud',
          body: 'Every sample syncs to Supabase. Decade of history on day one. Queryable from anywhere — not just your home network.',
        },
        {
          step: '03',
          title: 'AI reads your health',
          body: 'Connect the MCP server to Claude Code, n8n, or any MCP client. Your agent now has native health tool calls.',
        },
      ].map(({ step, title, body }) => (
        <div class="border border-neutral-800 rounded-xl p-6">
          <div class="text-green-400/50 text-xs font-bold mb-4">{step}</div>
          <h3 class="text-white font-semibold mb-3">{title}</h3>
          <p class="text-neutral-400 text-sm leading-relaxed">{body}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Why section -->
  <section class="px-6 py-16 border-t border-neutral-800/60">
    <div class="max-w-5xl mx-auto">
      <p class="text-xs text-neutral-500 uppercase tracking-widest mb-12">Why health4.ai</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        {[
          {
            label: 'Works with Claude Code',
            detail: "Anthropic's native Apple Health connector only works on claude.ai web. Claude Code, Codex, and API-based agents get nothing. We fix that.",
          },
          {
            label: 'Reliable background sync',
            detail: 'Health Auto Export requires your phone to be awake. We use the correct iOS architecture (HKObserverQuery) — sync happens whether you open the app or not.',
          },
          {
            label: 'Open source · MIT',
            detail: 'Self-host the entire stack or use our hosted tier. No lock-in. Your data goes to your Supabase endpoint.',
          },
          {
            label: 'Privacy-first',
            detail: "Big tech health AI is opaque about data use. health4.ai routes your data to your own endpoint. We can't read it.",
          },
        ].map(({ label, detail }) => (
          <div class="flex gap-4">
            <div class="mt-1 w-5 h-5 flex-shrink-0 text-green-400">
              <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
            </div>
            <div>
              <p class="text-white font-medium text-sm mb-1">{label}</p>
              <p class="text-neutral-400 text-sm leading-relaxed">{detail}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Pricing teaser -->
  <section class="px-6 py-16 border-t border-neutral-800/60">
    <div class="max-w-5xl mx-auto flex flex-col sm:flex-row gap-4">
      <div class="flex-1 border border-neutral-800 rounded-xl p-6">
        <p class="text-neutral-400 text-xs uppercase tracking-widest mb-2">Self-hosted</p>
        <p class="text-3xl font-bold text-white mb-1">Free</p>
        <p class="text-neutral-500 text-sm">Forever. MIT license. Bring your own Supabase.</p>
      </div>
      <div class="flex-1 border border-green-400/30 rounded-xl p-6 bg-green-400/5">
        <p class="text-green-400 text-xs uppercase tracking-widest mb-2">Hosted Pro</p>
        <p class="text-3xl font-bold text-white mb-1">$3<span class="text-lg font-normal text-neutral-400">/mo</span></p>
        <p class="text-neutral-500 text-sm">Cloud Supabase, remote MCP endpoint, no setup.</p>
      </div>
    </div>
  </section>

  <!-- Footer CTA -->
  <section class="px-6 py-24 text-center">
    <h2 class="text-2xl font-bold text-white mb-4">Get notified at App Store launch</h2>
    <p class="text-neutral-400 text-sm mb-8">No spam. One email when it's ready.</p>
    <form id="waitlist-form-2" class="flex flex-col sm:flex-row gap-3 max-w-sm mx-auto">
      <input
        type="email"
        id="email-input-2"
        placeholder="your@email.com"
        required
        class="flex-1 bg-neutral-900 border border-neutral-700 rounded-lg px-4 py-3 text-white placeholder-neutral-500 focus:outline-none focus:border-green-400 transition-colors text-sm"
      />
      <button
        type="submit"
        class="bg-green-500 hover:bg-green-400 text-black font-semibold px-6 py-3 rounded-lg transition-colors text-sm"
      >
        Notify me
      </button>
    </form>
    <p id="form-status-2" class="text-sm mt-3 text-neutral-500 min-h-[20px]"></p>
  </section>

  <!-- Footer -->
  <footer class="border-t border-neutral-800/60 px-6 py-8">
    <div class="max-w-5xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4 text-neutral-600 text-xs">
      <span>© 2026 health4.ai · MIT License</span>
      <a href="https://github.com/jefflitt1/health4ai" target="_blank" rel="noopener" class="hover:text-neutral-400 transition-colors">
        View on GitHub →
      </a>
    </div>
  </footer>
</Layout>

<script define:vars={{ SUPABASE_URL, SUPABASE_ANON_KEY }}>
  async function submitWaitlist(email, statusEl) {
    statusEl.textContent = 'Submitting…';
    try {
      const res = await fetch(`${SUPABASE_URL}/rest/v1/health4ai_waitlist`, {
        method: 'POST',
        headers: {
          'apikey': SUPABASE_ANON_KEY,
          'Authorization': `Bearer ${SUPABASE_ANON_KEY}`,
          'Content-Type': 'application/json',
          'Prefer': 'return=minimal',
        },
        body: JSON.stringify({ email }),
      });
      if (res.ok || res.status === 409) {
        statusEl.textContent = res.status === 409
          ? "You're already on the list."
          : "You're on the list. We'll email you at launch.";
        statusEl.classList.add('text-green-400');
      } else {
        throw new Error(res.status);
      }
    } catch {
      statusEl.textContent = 'Something went wrong. Try again.';
      statusEl.classList.add('text-red-400');
    }
  }

  document.getElementById('waitlist-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = document.getElementById('email-input').value;
    await submitWaitlist(email, document.getElementById('form-status'));
  });

  document.getElementById('waitlist-form-2')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = document.getElementById('email-input-2').value;
    await submitWaitlist(email, document.getElementById('form-status-2'));
  });
</script>
