---
import PostHog from '../components/posthog.astro';
interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'health4.ai — Apple Health data for AI',
  description = 'Free iOS app that connects Apple Health to Claude, ChatGPT, Cursor, and any AI. Ask about your sleep, recovery, and fitness in plain language.',
} = Astro.props;

const clarityId   = import.meta.env.PUBLIC_CLARITY_PROJECT_ID as string | undefined;
const metaPixelId = import.meta.env.PUBLIC_META_PIXEL_ID as string | undefined;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- OG -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content="https://health4.ai" />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="https://health4.ai/logo.png" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Structured data -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "health4.ai",
      "url": "https://health4.ai",
      "description": "Free iOS app that connects Apple Health to Claude, ChatGPT, Cursor, and any AI. Ask about your sleep, recovery, and fitness in plain language.",
      "applicationCategory": "HealthApplication",
      "operatingSystem": "iOS",
      "softwareVersion": "1.0",
      "offers": [{ "@type": "Offer", "price": "0", "priceCurrency": "USD" }],
      "sameAs": "https://github.com/jefflitt1/health4ai"
    }
    </script>

    <!-- CSP -->
    <meta
      http-equiv="Content-Security-Policy"
      content="default-src 'self'; script-src 'self' 'unsafe-inline' https://us.i.posthog.com https://us-assets.i.posthog.com https://www.clarity.ms https://connect.facebook.net; style-src 'self' 'unsafe-inline'; connect-src 'self' https://donnmhbwhpjlmpnwgdqr.supabase.co https://us.i.posthog.com https://us-assets.i.posthog.com https://www.clarity.ms https://*.clarity.ms https://r.clarity.ms https://www.facebook.com https://connect.facebook.net; img-src 'self' data: https://www.facebook.com; font-src 'self';"
    />

    <!-- PostHog -->
    <PostHog />

    <!-- Microsoft Clarity -->
    {clarityId && (
      <script is:inline set:html={`(function(c,l,a,r,i,t,y){c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y)})(window,document,"clarity","script","${clarityId}");`}></script>
    )}

    <!-- Meta Pixel -->
    {metaPixelId && (
      <script is:inline set:html={`!function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,document,'script','https://connect.facebook.net/en_US/fbevents.js');fbq('init','${metaPixelId}');fbq('track','PageView');`}></script>
    )}
    {metaPixelId && <noscript><img height="1" width="1" style="display:none" src={`https://www.facebook.com/tr?id=${metaPixelId}&ev=PageView&noscript=1`}/></noscript>}
  </head>
  <body class="bg-[#0a0c1a] text-white antialiased" style="font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;">
    <slot />
  </body>
</html>

<style is:global>
  @import 'tailwindcss';
  * { box-sizing: border-box; }

  :root {
    --accent: #ff2d78;
    --accent-light: #ff6b9d;
    --accent-glow: rgba(255, 45, 120, 0.22);
    --surface: #0f1225;
    --border: rgba(255, 45, 120, 0.14);
    --muted: #9ba5c4;
  }

  @keyframes ecg-draw {
    0%   { stroke-dashoffset: 950; opacity: 0; }
    8%   { opacity: 1; }
    68%  { stroke-dashoffset: 0; opacity: 1; }
    88%  { stroke-dashoffset: 0; opacity: 0.8; }
    100% { stroke-dashoffset: 950; opacity: 0; }
  }
  @keyframes peak-pulse {
    0%, 15%, 85%, 100% { opacity: 0; transform: scale(0.4); }
    40%, 60%           { opacity: 1; transform: scale(1); }
    50%                { transform: scale(1.4); }
  }
  @keyframes ring-breathe {
    0%, 100% { opacity: 0.45; }
    50%      { opacity: 0.85; }
  }
  @keyframes float-up {
    0%, 100% { transform: translateY(0); }
    50%      { transform: translateY(-7px); }
  }
  @keyframes fade-in-up {
    from { opacity: 0; transform: translateY(14px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes glow-pulse {
    0%, 100% { box-shadow: 0 0 18px var(--accent-glow); }
    50%      { box-shadow: 0 0 36px rgba(255,45,120,0.38); }
  }
</style>
