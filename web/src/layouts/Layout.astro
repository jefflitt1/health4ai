---
interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'health4.ai — Apple Health data for AI',
  description = 'Open-source iOS app + cloud MCP server. Give Claude, n8n, and any AI agent native access to your Apple Health data.',
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- OG -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content="https://health4.ai" />
    <meta property="og:type" content="website" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Structured data -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "health4.ai",
      "url": "https://health4.ai",
      "description": "Open-source iOS app and MCP server that syncs Apple HealthKit data to Supabase and gives Claude Code, ChatGPT, and any AI agent native access to your health data.",
      "applicationCategory": "HealthApplication",
      "operatingSystem": "iOS",
      "softwareVersion": "1.0",
      "license": "https://opensource.org/licenses/MIT",
      "codeRepository": "https://github.com/jefflitt1/health4ai",
      "offers": [
        {
          "@type": "Offer",
          "name": "Self-hosted",
          "price": "0",
          "priceCurrency": "USD",
          "description": "MIT open source — self-host with your own Supabase"
        },
        {
          "@type": "Offer",
          "name": "Hosted Pro",
          "price": "3",
          "priceCurrency": "USD",
          "description": "Managed cloud Supabase and remote MCP endpoint"
        }
      ],
      "sameAs": "https://github.com/jefflitt1/health4ai"
    }
    </script>

    <!-- CSP — analytics hosts day one (playbook §4.1) -->
    <meta
      http-equiv="Content-Security-Policy"
      content="default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; connect-src 'self' https://donnmhbwhpjlmpnwgdqr.supabase.co https://us.i.posthog.com https://us-assets.i.posthog.com https://www.clarity.ms https://*.clarity.ms https://r.clarity.ms; img-src 'self' data:; font-src 'self';"
    />
  </head>
  <body class="bg-[#0d0d0d] text-white font-mono antialiased">
    <slot />
  </body>
</html>

<style is:global>
  @import 'tailwindcss';
  * { box-sizing: border-box; }
</style>
