# health4ai MCP Server — environment variables
# Copy to .env and fill in your values

# ── Primary: explicit Postgres connection string (any backend) ──────────────
# Supabase: Settings > Database > Connection string (Transaction pooler, port 6543)
#   postgresql://postgres.<project_ref>:<service_role_key>@aws-0-us-east-1.pooler.supabase.com:6543/postgres
# Neon:     Connection Details > Connection string
# Local:    postgresql://postgres:yourpassword@localhost:5432/postgres
DATABASE_URL=postgresql://your_user:your_password@your_host:5432/your_db

# ── Fallback: Supabase-only env vars (used when DATABASE_URL is not set) ───
# If DATABASE_URL is absent, the server auto-constructs the Supabase transaction
# pooler URL from the project ref (extracted from SUPABASE_URL) and the key.
# Format constructed:
#   postgresql://postgres.<ref>:<key>@aws-0-us-east-1.pooler.supabase.com:6543/postgres
# Uncomment and fill these in instead of DATABASE_URL if you prefer this style:
# SUPABASE_URL=https://yourprojectref.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── Required ─────────────────────────────────────────────────────────────────
# Identifier for your data rows (any string — email, username, or UUID)
# Must match what the iOS app used when writing data
HEALTHKIT_USER_ID=your_user_id_here
